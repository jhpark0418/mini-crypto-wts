{
  "name": "crypto-market-pipeline",
  "private": true,
  "version": "1.0.0",
  "description": "Real-time crypto market data pipeline with Binance, Kafka, Redis, PostgreSQL, NestJS, and React",
  "main": "index.js",
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "dev:market": "npm -w apps/market-ingestor run dev",
    "dev:candle": "npm -w apps/candle-service run dev",
    "dev:api": "npm -w apps/api-gateway run start:dev",
    "dev:web": "npm -w apps/web run dev",
    "build": "npm -ws run build",
    "lint": "npm -ws run lint",
    "format": "prettier . --write"
  },
  "keywords": [],
  "author": "Junghoon Park",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@nestjs/typeorm": "^11.0.0",
    "dotenv": "^17.3.1",
    "lightweight-charts": "^5.1.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28"
  }
}
